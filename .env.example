# Gemini API Key (Get it from Google AI Studio)
GEMINI_API_KEY=your_api_key_here

# JWT Secret for authentication (Generate a strong random string)
JWT_SECRET=your_jwt_secret_here

# Allowed origins for CORS (e.g., http://localhost:3000)
ALLOWED_ORIGINS=http://localhost:3000

# Rate limit for API requests (Requests per minute)
RATE_LIMIT_RPM=30

# MongoDB Connection URI (Atlas)
# Example: mongodb+srv://<username>:<password>@cluster.mongodb.net/smart-keyboard?retryWrites=true&w=majority
# MongoDB Connection URI (Atlas)

